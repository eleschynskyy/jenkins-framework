# --- Deploy to k3d (run from repo root) ---
# k3d cluster delete perf-sandbox
# k3d cluster create perf-sandbox
# docker build -t sandbox/jenkins:latest jenkins/
# k3d image import sandbox/jenkins:latest -c perf-sandbox

# 1. Create namespace and RBAC (ServiceAccount + Role + RoleBinding)
kubectl apply -f jenkins/namespace.yaml
kubectl apply -f jenkins/jenkins-rbac.yaml

# 2. Create ConfigMaps (run from repo root; or from jenkins/ and fix paths)
kubectl create configmap jenkins-casc --from-file=casc.yaml=jenkins/casc_configs/casc.yaml -n sandbox --dry-run=client -o yaml | kubectl apply -f -
kubectl create configmap jenkins-jobs --from-file=jenkins/jobs-dsl/ -n sandbox --dry-run=client -o yaml | kubectl apply -f -

# 3. Deploy Jenkins and Service
kubectl apply -f jenkins/jenkins-deployment.yaml
kubectl apply -f jenkins/jenkins-service.yaml

# 4. Check and access
kubectl get po -n sandbox
kubectl port-forward -n sandbox svc/jenkins 8080:8080

security:
  scriptApproval:
    approvedSignatures:
      - "staticMethod jenkins.model.Jenkins getInstance"
      - "method jenkins.model.Jenkins getNode java.lang.String"
      - "method hudson.model.Node getNumExecutors"

        stage('Show Executors') {
            steps {
                script {
                    def nodeName = env.NODE_NAME
                    echo "Current node: ${nodeName}"
                    def node = jenkins.model.Jenkins.instance.getNode(nodeName)
    
                    if (node == null) {
                        def masterExecutors = jenkins.model.Jenkins.instance.numExecutors
                        echo "Running on master node with ${masterExecutors} executor(s)"
                    } else {
                        echo "Node '${nodeName}' has ${node.numExecutors} executor(s)"
                    }
                }
            }
        }